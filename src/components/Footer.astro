---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p class="footer-brand">Stride City Run Club</p>
		<p class="footer-copy">&copy; {today.getFullYear()} Stride City Run Club. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		background: rgb(var(--black));
		color: rgba(255, 255, 255, 0.6);
		padding: 2.5em 1.5em;
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		text-align: center;
	}
	.footer-brand {
		font-weight: 700;
		font-size: 1rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #fff;
		margin: 0 0 0.5em;
	}
	.footer-copy {
		font-size: 0.85rem;
		margin: 0;
	}
</style>
