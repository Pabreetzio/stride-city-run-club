---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<div class="header-wrap">
<div class="topbar">
	<div class="topbar-inner">
		<div class="topbar-info">
			<!-- Calendar icon -->
			<span class="topbar-item">
				<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
					<line x1="16" y1="2" x2="16" y2="6"></line>
					<line x1="8" y1="2" x2="8" y2="6"></line>
					<line x1="3" y1="10" x2="21" y2="10"></line>
				</svg>
				6:30 Wednesdays
			</span>
			<span class="topbar-pipe" aria-hidden="true">|</span>
			<!-- Location pin icon -->
			<span class="topbar-item">
				<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"></path>
					<circle cx="12" cy="10" r="3"></circle>
				</svg>
				6697 Monroe Rd, Charlotte, NC 28212
			</span>
		</div>
		<div class="topbar-social">
			<a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Stride City on Facebook">
				<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
				</svg>
			</a>
			<a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Stride City on Instagram">
				<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
					<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
					<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
				</svg>
			</a>
		</div>
	</div>
</div>

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/runs">Runs</HeaderLink>
			<HeaderLink href="/blog">News</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
</div>

<style>
	.header-wrap {
		position: sticky;
		top: 0;
		z-index: 100;
	}

	/* ── Topbar ── */
	.topbar {
		background: var(--accent);
		padding: 0 1.5em;
		border-bottom: 1px solid rgba(0, 0, 0, 0.1);
	}
	.topbar-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		height: 34px;
	}
	.topbar-info {
		display: flex;
		align-items: center;
		gap: 0.6em;
		font-size: 0.72rem;
		color: rgba(0, 0, 0, 0.75);
		letter-spacing: 0.03em;
	}
	.topbar-item {
		display: flex;
		align-items: center;
		gap: 0.35em;
	}
	.topbar-pipe {
		font-weight: 700;
		color: rgba(0, 0, 0, 0.3);
		line-height: 1;
	}
	.topbar-social {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}
	.topbar-social a {
		display: flex;
		align-items: center;
		color: rgba(0, 0, 0, 0.55);
		text-decoration: none;
		transition: color 0.15s;
	}
	.topbar-social a:hover {
		color: rgb(var(--black));
	}

	/* ── Main nav ── */
	header {
		margin: 0;
		padding: 0 1.5em;
		background: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		height: 60px;
	}
	.site-title {
		font-family: var(--font-teko);
		font-size: 1.5rem;
		font-weight: 600;
		color: #fff;
		text-decoration: none;
		letter-spacing: 0.02em;
		text-transform: uppercase;
	}
	.site-title:hover {
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		gap: 0.25em;
	}
	.nav-links :global(a) {
		font-family: var(--font-teko);
		padding: 0.5em 0.75em;
		color: rgba(255, 255, 255, 0.7);
		border-bottom: none;
		text-decoration: none;
		text-transform: uppercase;
		transition: color 0.15s;
	}
	.nav-links :global(a:hover) {
		color: #fff;
	}
	.nav-links :global(a.active) {
		color: var(--accent);
	}

	/* ── Responsive ── */
	@media (max-width: 640px) {
		.topbar-info {
			font-size: 0.65rem;
			gap: 0.4em;
		}
	}
	@media (max-width: 480px) {
		.topbar {
			display: none;
		}
		.site-title {
			font-size: 0.9rem;
		}
		.nav-links :global(a) {
			padding: 0.5em 0.4em;
			font-size: 0.8rem;
		}
	}
</style>
