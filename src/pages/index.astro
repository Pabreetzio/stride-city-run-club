---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import '../styles/home.scss';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<section class="hero">
			<div class="hero-inner">
				<h1><span class="accent">Running</span> Together,<br />Building Community</h1>
				<p class="hero-sub">
					Join us every Wednesday night at Edge City Brewery at 6:30pm. All ages and fitness levels welcome, walk or run. The route is two miles.
				</p>
				<a href="/runs" class="btn-primary">See Upcoming Runs</a>
			</div>
		</section>

		<section class="about-strip">
			<div class="container">
				<h2>Who We Are</h2>
				<p>
					We're a community of runners who believe the best miles are shared ones.
					Whether you're chasing a PR or just looking for a reason to get outside,
					there's a place for you here.
				</p>
			</div>
		</section>

		{recentPosts.length > 0 && (
			<section class="news">
				<div class="container">
					<h2>Latest News</h2>
					<ul class="post-list">
						{recentPosts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="post-title">{post.data.title}</span>
									<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
								</a>
							</li>
						))}
					</ul>
					<a href="/blog" class="btn-secondary">All Posts</a>
				</div>
			</section>
		)}

		<Footer />
	</body>
</html>
