---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Upcoming Runs — Stride City Run Club" description="Find our next group run." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Upcoming Runs</h1>
			<p>Run schedule coming soon. Check back here for dates, times, and meeting spots.</p>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 700px;
		margin: 0 auto;
		padding: 4em 1.5em;
	}
	h1 {
		margin-bottom: 0.75em;
	}
</style>
